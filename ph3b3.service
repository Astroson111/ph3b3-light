[Unit]
Description=Ph3b3 AI Assistant Server
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
User=lex_lson
WorkingDirectory=/home/lex_lson/ph3b3
EnvironmentFile=/home/lex_lson/ph3b3/.env
# piper (TTS) and aplay live outside systemd's minimal default PATH — pipx puts
# piper in ~/.local/bin and pip puts it in the venv. Without this the server
# starts but TTS silently fails with "piper: command not found".
Environment=PATH=/home/lex_lson/ph3b3/.venv/bin:/home/lex_lson/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/lex_lson/ph3b3/.venv/bin/python agent/server.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ph3b3

[Install]
WantedBy=multi-user.target
