# Ph3b3 environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Web UI auth ──────────────────────────────────────────────────────────────
# Username and password for HTTP basic auth on the web UI.
# Leave PH3B3_PASSWORD blank to disable auth (not recommended on a networked machine).
PH3B3_USER=your_username
PH3B3_PASSWORD=your_password_here

# ── Server ───────────────────────────────────────────────────────────────────
PH3B3_HOST=0.0.0.0
PH3B3_PORT=7331
# Origins allowed for BOTH browser CORS *and* the /ws WebSocket handshake.
# IMPORTANT: the Stack-chan firmware's WebSocket library sends `Origin: file://`,
# so `file://` MUST be in this list or the device handshake is rejected with
# `Rejected WS handshake (origin='file://')`. Keep localhost for the web UI.
# (The Stack-chan is NOT an originless native client — it does send an Origin.)
PH3B3_CORS_ORIGINS=http://localhost:7331,http://127.0.0.1:7331,file://
# Optional shared secret required on the /ws WebSocket handshake (extra auth on top
# of the Origin check). Unset = no token required. If set, append ?token=<value> to
# the WS URL (e.g. firmware PH3B3_PATH "/ws/stackchan?token=...").
# PH3B3_WS_TOKEN=

# ── Web search (Metis) ───────────────────────────────────────────────────────
# Web access (egress) is OFF by default — privacy-first. Turn it on per-session
# from the Status page in either portal. When on, your search queries leave this
# machine; searches are always announced in the reply and cited with sources.
# Set to "on" only if you want it pre-armed at boot.
PH3B3_WEB_ACCESS=off
# Backend: auto | searxng | ddg
#   auto    — use SearXNG if configured & reachable at boot, else DuckDuckGo.
#   searxng — your own SearXNG instance (aggregated + anonymised through you).
#   ddg     — scrape DuckDuckGo directly. Zero setup; queries go straight to DDG.
PH3B3_SEARCH_BACKEND=auto
# Your SearXNG instance URL — bind it to localhost. Leave blank to use DuckDuckGo.
# PH3B3_SEARXNG_URL=http://localhost:8080

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
PH3B3_MODEL=hermes3
# Optional model routing: turns that call only lightweight tools use the light
# model; everything else uses the heavy model. Both default to PH3B3_MODEL.
# PH3B3_HEAVY_MODEL=hermes3:latest
# PH3B3_LIGHT_MODEL=hermes3:latest

# ── Vision ───────────────────────────────────────────────────────────────────
# Model used for camera/image analysis. Must be a multimodal model in Ollama.
PH3B3_VISION_MODEL=llava

# ── Speech ───────────────────────────────────────────────────────────────────
# Full path to a Piper .onnx voice model file.
# Default: ~/ph3b3_data/voices/en_GB-alba-medium.onnx
# PH3B3_VOICE_MODEL=/home/youruser/ph3b3_data/voices/en_GB-alba-medium.onnx

# Whisper model size: tiny, base, small, medium, large
# Larger = more accurate, slower, more VRAM.
PH3B3_WHISPER_MODEL=medium

# ── Spotify ───────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Set the redirect URI in the Spotify app settings to: http://127.0.0.1:8888/callback
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── WireGuard (optional) ─────────────────────────────────────────────────────
# If set, start.sh will bring up this WireGuard interface before starting.
# Leave unset to skip WireGuard entirely.
# WG_INTERFACE=wg0

# ── Weather ───────────────────────────────────────────────────────────────────
# OpenWeatherMap API key — free tier is sufficient.
# https://openweathermap.org/api
PH3B3_OWM_KEY=your_openweathermap_api_key
# Default location for weather lookups. If unset, Ph3b3 asks rather than assuming.
# Format: "City,ST" or "City,Country"
PH3B3_DEFAULT_LOCATION=

# ── Privacy / retention ───────────────────────────────────────────────────────
# Days to keep network scan data — the scan log (~/ph3b3_data/network/scan_log.jsonl)
# and raw scan files (~/ph3b3_data/scans/scan_*.txt), which record device IPs/MACs.
# Old entries/files are purged on write and at boot. Default 7; 0 = keep forever.
# PH3B3_SCAN_LOG_TTL_DAYS=7
#
# Days to keep camera captures — photos, videos, look-frames, and anomaly snapshots
# under ~/ph3b3_data/{photos,videos,captures,anomalies}. This is room imagery.
# Old files are deleted on capture and at boot. Default 7; 0 = keep forever.
# PH3B3_CAPTURE_TTL_DAYS=7
